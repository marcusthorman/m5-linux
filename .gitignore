# IPSW files — large, download from Apple CDN
ipsw/*.ipsw

# Extracted firmware blobs — not redistributable (Apple copyright)
analysis/*/extracted/
analysis/*/fw/
*.im4p
*.payload
# Downloaded BuildManifests (Apple firmware metadata) — re-fetch via the script
analysis/manifests/*/

# Python venv
.venv/

# Ghidra projects
*.gpr
*.rep/

# Binary analysis artifacts
*.i64
*.id0
*.id1
*.id2
*.nam
*.til

# Reference repos and downloaded tools (re-fetch locally)
tools/m1n1-ref/
tools/linux-ref/
tools/ipsw

# Extracted XNU kexts and kernelcaches — Apple firmware, not redistributable
analysis/adt/kernels/
analysis/xnu/

# Build artifacts
*.o
*.ko
*.dtb.tmp
# iBoot payloads are also Apple firmware, already covered by *.payload above

# Claude Code per-machine settings — personal risk acceptances, not shared
.claude/settings.local.json

# Build workspace — cloned upstream repos and build outputs
build/
